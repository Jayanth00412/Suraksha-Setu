<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A0A">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="#1E1E1E"
            android:tint="#AAAAAA"
            android:padding="8dp"
            android:layout_marginRight="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SURAKSHA-SETU"
                android:textColor="#EF4444"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TRUST CIRCLE"
                android:textColor="#555555"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Add Contact Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="16dp"
        android:backgroundTint="#1E1E1E">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ADD NUMBER"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/etCircleName"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Contact Name"
                android:textColorHint="#555555"
                android:textColor="#FFFFFF"
                android:background="@drawable/edit_text_bg"
                android:paddingLeft="16dp"
                android:inputType="textPersonName"
                android:layout_marginBottom="10dp" />

            <EditText
                android:id="@+id/etCirclePhone"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Phone Number (e.g. +91 99XXXXXXXX)"
                android:textColorHint="#555555"
                android:textColor="#FFFFFF"
                android:background="@drawable/edit_text_bg"
                android:paddingLeft="16dp"
                android:inputType="phone"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnAddCircleContact"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="ADD TO TRUST CIRCLE"
                android:backgroundTint="#EF4444"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Contacts List Label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MY TRUST CIRCLE"
        android:textColor="#888888"
        android:textSize="11sp"
        android:textStyle="bold"
        android:layout_marginLeft="16dp"
        android:layout_marginBottom="8dp" />

    <!-- Contacts RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTrustCircle"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:clipToPadding="false" />

</LinearLayout>
