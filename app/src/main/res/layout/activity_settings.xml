<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#121212">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="System Settings"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp" />

    <Switch
        android:id="@+id/switchShake"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Shake Detection"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:padding="16dp" />

    <Switch
        android:id="@+id/switchPowerTap"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Power Button Tap"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:padding="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap Sensitivity (3 to 6 taps)"
        android:textColor="#888888"
        android:layout_marginLeft="16dp" />

    <SeekBar
        android:id="@+id/seekPowerSensitivity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:max="3"
        android:progress="0" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Note: Power button tap requires background service to be active."
        android:textColor="#555555"
        android:textSize="12sp" />

</LinearLayout>
